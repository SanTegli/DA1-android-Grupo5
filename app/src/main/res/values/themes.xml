<resources xmlns:tools="http://schemas.android.com/apk/res/android">

    <!-- Base application theme. -->
    <style name="Base.Theme.AndroidNativeGrupo5" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Customize your light theme here. -->
        <item name="android:fontFamily">@font/plus_jakarta_sans_regular</item>
    </style>

    <style name="Theme.AndroidNativeGrupo5" parent="Base.Theme.AndroidNativeGrupo5" />

    <!-- SPLASH SCREEN -->
    <style name="Theme.App.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#FFFFFF</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="windowSplashScreenIconBackgroundColor">#FFFFFF</item>
        <item name="postSplashScreenTheme">@style/Theme.AndroidNativeGrupo5</item>
    </style>

    <style name="Widget.AdventurousTourism.Button" parent="Widget.MaterialComponents.Button">
        <item name="materialThemeOverlay">@style/ThemeOverlay.App.Button.Primary</item>
        <item name="android:padding">16dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans_medium</item>
    </style>

    <style name="Widget.AdventurousTourism.Button.TextButton" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">@color/secondary</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans_medium</item>
    </style>

    <style name="Widget.AdventurousTourism.Button.OutlinedButton" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/secondary</item>
        <item name="strokeWidth">1dp</item>
        <item name="android:textColor">@color/secondary</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:fontFamily">@font/plus_jakarta_sans_medium</item>
    </style>

    <style name="ThemeOverlay.App.Button.Primary" parent="">
        <item name="colorPrimary">@color/primary_container</item>
        <item name="colorOnPrimary">@color/on_primary</item>
    </style>

    <style name="CustomDatePickerTheme" parent="Theme.MaterialComponents.Light.Dialog.Alert">
        <item name="colorPrimary">#7F0303</item>
        <item name="colorPrimaryDark">#7F0303</item>
        <item name="colorAccent">#7F0303</item>
        <item name="android:colorAccent">#7F0303</item>
        <item name="android:textColorPrimary">#1E1B16</item>
        <item name="android:textColorSecondary">#7F0303</item>
    </style>

    <style name="DatePickerButtonStyle" parent="@style/Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">#7F0303</item>
    </style>
    <style name="CustomDialogTheme" parent="ThemeOverlay.MaterialComponents.MaterialAlertDialog">

        <!-- Fondo -->
        <item name="colorSurface">#FFFFFF</item>

        <!-- Título -->
        <item name="materialAlertDialogTitleTextStyle">@style/DialogTitleStyle</item>

        <!-- Mensaje -->
        <item name="materialAlertDialogBodyTextStyle">@style/DialogBodyStyle</item>

        <!-- Botones -->
        <item name="buttonBarPositiveButtonStyle">@style/DialogButtonStyle</item>
        <item name="buttonBarNegativeButtonStyle">@style/DialogButtonStyle</item>

    </style>

    <style name="DialogTitleStyle" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">#1E1B16</item>
    </style>

    <style name="DialogBodyStyle" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textColor">#6F747C</item>
    </style>

    <style name="DialogButtonStyle" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textColor">#7F0303</item> <!-- tu rojo -->
    </style>

</resources>