<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/surface_container_lowest">

    <View
        android:id="@+id/headerBg"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/surface_container"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/text_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="24dp"
        android:fontFamily="@font/plus_jakarta_sans_bold"
        android:text="Mis reservas"
        android:textColor="@color/on_surface"
        android:textSize="22sp"
        app:layout_constraintBottom_toBottomOf="@id/headerBg"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/headerBg" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_go_history"
        style="@style/Widget.AdventurousTourism.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:fontFamily="@font/plus_jakarta_sans_bold"
        android:text="Historial"
        android:textSize="14sp"
        app:layout_constraintBottom_toBottomOf="@id/headerBg"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/headerBg" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recycler_reservations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@id/headerBg"
        tools:listitem="@layout/item_reservation" />

    <TextView
        android:id="@+id/layoutOfflineWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="#FFF3CD"
        android:fontFamily="@font/plus_jakarta_sans_regular"
        android:padding="8dp"
        android:text="Modo sin conexión. Mostrando reservas guardadas."
        android:textAlignment="center"
        android:textColor="#856404"
        android:textSize="12sp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/headerBg" />

</androidx.constraintlayout.widget.ConstraintLayout>