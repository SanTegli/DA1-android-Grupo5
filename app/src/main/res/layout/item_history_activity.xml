<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/card_history"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="24dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="24dp"
    app:cardElevation="0dp"
    app:strokeWidth="0dp"
    app:cardBackgroundColor="@color/surface_container_lowest">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/text_history_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            android:textColor="@color/primary"
            android:textSize="12sp"
            android:textAllCaps="true"
            tools:text="10 ABR 2026" />

        <TextView
            android:id="@+id/text_history_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            android:textColor="@color/on_surface"
            android:textSize="18sp"
            tools:text="Tour por el Coliseo Romano" />

        <TextView
            android:id="@+id/text_history_destination"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:fontFamily="@font/plus_jakarta_sans_regular"
            android:textColor="@color/on_surface_variant"
            android:textSize="14sp"
            tools:text="Roma, Italia" />

        <TextView
            android:id="@+id/text_history_guide"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:fontFamily="@font/plus_jakarta_sans_regular"
            android:textColor="@color/on_surface_variant"
            android:textSize="13sp"
            tools:text="Guía: Marco Rossi" />

        <LinearLayout
            android:id="@+id/layout_rating_info"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@color/surface_container_highest"
            android:orientation="vertical"
            android:padding="16dp"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/text_rating_activity"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp"
                    tools:text="Actividad: ★★★★☆" />

                <TextView
                    android:id="@+id/text_rating_guide"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="12dp"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:textColor="@color/on_surface"
                    android:textSize="12sp"
                    tools:text="Guía: ★★★★★" />
            </LinearLayout>

            <TextView
                android:id="@+id/text_rating_comment"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"
                android:textColor="@color/on_surface_variant"
                android:textSize="13sp"
                android:fontStyle="italic"
                tools:text="&quot;Excelente experiencia, muy recomendable.&quot;" />
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_rate_experience"
            style="@style/Widget.AdventurousTourism.Button.TextButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="12dp"
            android:fontFamily="@font/plus_jakarta_sans_bold"
            android:text="Calificar experiencia"
            android:textColor="@color/primary"
            android:visibility="gone"
            tools:visibility="visible" />

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>