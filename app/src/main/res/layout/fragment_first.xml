<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- 🔍 HEADER / SEARCH -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Where to next,\nAdventurer?"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/app_text"
            android:fontFamily="@font/plus_jakarta_sans_bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <EditText
                android:id="@+id/editSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/app_input"
                android:hint="Search experiences..."
                android:textColor="@color/app_text"
                android:textColorHint="@color/app_text_secondary"
                android:padding="16dp"
                android:fontFamily="@font/plus_jakarta_sans_regular"/>

            <ImageButton
                android:id="@+id/btnFilter"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:layout_marginStart="12dp"
                android:background="@color/app_accent"
                android:src="@drawable/ic_tune"
                android:tint="@android:color/white"/>
        </LinearLayout>

        <!-- ⭐ FEATURED (IMPORTANTE: ESTE ID ES EL QUE TE FALTABA) -->
        <LinearLayout
            android:id="@+id/layoutFeatured"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="32dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Featured Experiences"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/app_text"
                android:fontFamily="@font/plus_jakarta_sans_bold"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerFeatured"
                android:layout_width="match_parent"
                android:layout_height="250dp"
                android:layout_marginTop="12dp"/>
        </LinearLayout>

        <!-- 📍 POPULAR -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Popular Near You"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/app_text"
            android:layout_marginTop="32dp"
            android:fontFamily="@font/plus_jakarta_sans_bold"/>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerActivities"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:layout_marginTop="12dp"/>

        <!-- 🔄 LOADING -->
        <ProgressBar
            android:id="@+id/progressBar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_gravity="center"
            android:layout_marginTop="20dp"
            android:visibility="gone"/>

        <!-- 🔘 MIS RESERVAS -->
        <Button
            android:id="@+id/btnMyReservations"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Mis Reservas"
            android:textColor="@android:color/white"
            android:background="@color/app_primary"
            android:layout_marginTop="24dp"
            android:fontFamily="@font/plus_jakarta_sans_bold"/>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>