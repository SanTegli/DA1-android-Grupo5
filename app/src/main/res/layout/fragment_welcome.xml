<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:padding="24dp"
    android:gravity="center">

    <!-- WELCOME ILLUSTRATION -->
    <ImageView
        android:id="@+id/imgWelcome"
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_marginBottom="32dp"
        android:src="@drawable/common_illustration_welcome_placeholder" />

    <TextView
        android:id="@+id/txtWelcomeTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¡Bienvenido a XploreNow!"
        android:textColor="#1A1A1A"
        android:textSize="28sp"
        android:fontFamily="@font/plus_jakarta_sans_bold"
        android:gravity="center"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/txtWelcomeSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Descubre las mejores experiencias, tours y actividades cerca de ti. Tu aventura comienza aquí."
        android:textColor="#666666"
        android:textSize="16sp"
        android:fontFamily="@font/plus_jakarta_sans_regular"
        android:gravity="center"
        android:layout_marginBottom="48dp" />

    <!-- BIOMETRIC BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnBiometric"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginBottom="16dp"
        android:text="Acceder con Biometría"
        android:textColor="#7F0303"
        app:backgroundTint="#FDF2F2"
        app:cornerRadius="16dp"
        app:icon="@drawable/common_ic_fingerprint"
        app:iconGravity="textStart"
        app:iconTint="#7F0303"
        android:fontFamily="@font/plus_jakarta_sans_bold" />

    <!-- LOGIN BUTTON -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnClassicLogin"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="Iniciar Sesión con Usuario"
        android:textColor="#FFFFFF"
        app:backgroundTint="#7F0303"
        app:cornerRadius="16dp"
        app:icon="@drawable/common_ic_login"
        app:iconGravity="textStart"
        app:iconTint="#FFFFFF"
        android:fontFamily="@font/plus_jakarta_sans_bold" />

    <!-- REGISTER TEXT -->
    <TextView
        android:id="@+id/tvRegisterWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="¿No tienes cuenta? Regístrate"
        android:textColor="#7F0303"
        android:textSize="14sp"
        android:fontFamily="@font/plus_jakarta_sans_bold"
        android:clickable="true"
        android:focusable="true" />

</LinearLayout>
