<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/filter_bg_filter_sheet">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- HANDLE -->
        <View
            android:layout_width="44dp"
            android:layout_height="5dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="14dp"
            android:layout_marginBottom="14dp"
            android:background="@drawable/filter_bg_filter_handle" />

        <!-- HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:id="@+id/btnCloseFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="×"
                android:textColor="#7F0303"
                android:textSize="28sp" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="14dp"
                android:layout_weight="1"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Filtros"
                android:textColor="#7F0303"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/btnClearFilters"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Reset"
                android:textColor="#7F0303"
                android:textSize="16sp" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#E1D2C2" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="24dp"
            android:paddingTop="24dp"
            android:paddingEnd="24dp"
            android:paddingBottom="32dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Estado de reserva"
                android:textColor="#1E1B16"
                android:textSize="22sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/filter_bg_filter_card_white"
                android:orientation="vertical"
                android:padding="14dp">

                <Spinner
                    android:id="@+id/spinnerReservationStatus"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:background="@drawable/filter_bg_filter_spinner"
                    android:popupBackground="@drawable/filter_bg_spinner_dropdown"
                    android:paddingStart="10dp"
                    android:paddingEnd="10dp" />

            </LinearLayout>

        </LinearLayout>

        <!-- FOOTER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="104dp"
            android:background="#FFFFFF"
            android:gravity="center"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <Button
                android:id="@+id/btnApplyFilters"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:backgroundTint="#7F0303"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Aplicar filtros  →"
                android:textAllCaps="false"
                android:textColor="#FFFFFF"
                android:textSize="20sp" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>