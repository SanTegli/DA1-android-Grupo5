<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/app_background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="300dp">

            <ImageView
                android:id="@+id/imageDetail"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@android:drawable/ic_menu_gallery" />

            <ImageButton
                android:id="@+id/btnFavoriteDetail"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:layout_margin="16dp"
                android:background="@drawable/bg_circle_white"
                android:src="@drawable/ic_heart_outline"
                app:tint="@color/app_primary" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:id="@+id/textTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textColor="@color/app_text"
                android:textSize="24sp"
                tools:text="Tour por la Ciudad" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:orientation="horizontal">

                <TextView
                    android:id="@+id/textCategory"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans_bold"
                    android:textColor="@color/app_primary"
                    android:textSize="14sp"
                    tools:text="Aventura" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginHorizontal="8dp"
                    android:text="•"
                    android:textColor="@color/app_text_secondary" />

                <TextView
                    android:id="@+id/textDestination"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="@font/plus_jakarta_sans_regular"
                    android:textColor="@color/app_text_secondary"
                    android:textSize="14sp"
                    tools:text="Bariloche" />
            </LinearLayout>

            <TextView
                android:id="@+id/textGuideName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:fontFamily="@font/plus_jakarta_sans_medium"
                android:textColor="@color/app_text_secondary"
                android:textSize="14sp"
                tools:text="Guía: Alex Smith" />

            <TextView
                android:id="@+id/textPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:textColor="@color/app_primary"
                android:textSize="20sp"
                tools:text="$99.99" />

            <!-- INFO RAPIDA -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:orientation="horizontal"
                android:weightSum="3">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_calendar" app:tint="@color/app_primary"/>
                    <TextView android:id="@+id/textDuration" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textSize="12sp" tools:text="3 horas"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_location" app:tint="@color/app_primary"/>
                    <TextView android:id="@+id/textLanguage" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textSize="12sp" android:text="Español"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:gravity="center"
                    android:orientation="vertical">
                    <ImageView android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/main_ic_person" app:tint="@color/app_primary"/>
                    <TextView android:id="@+id/textSlots" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="4dp" android:textSize="12sp" tools:text="10 cupos"/>
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="1dp" android:layout_marginVertical="20dp" android:background="#EEEEEE" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:fontFamily="@font/plus_jakarta_sans_bold" android:text="Descripción" android:textColor="@color/app_text" android:textSize="18sp" />
            <TextView android:id="@+id/textDescription" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:fontFamily="@font/plus_jakarta_sans_regular" android:lineSpacingExtra="4dp" android:textColor="@color/app_text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Qué incluye"
                android:textColor="@color/app_text"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textIncludes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="• Guía profesional\n• Equipo necesario\n• Traslados"
                android:textColor="@color/app_text_secondary" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Punto de encuentro"
                android:textColor="@color/app_text"
                android:textSize="18sp" />

            <TextView android:id="@+id/textMeetingPoint"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textColor="@color/app_text_secondary" />

            <com.google.android.gms.maps.MapView
                android:id="@+id/mapView"
                android:layout_width="match_parent"
                android:layout_height="180dp"
                android:layout_marginTop="12dp"
                app:cardCornerRadius="16dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHowToGetThere"
                style="@style/Widget.MaterialComponents.Button.TextButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Cómo llegar"
                app:icon="@drawable/ic_location" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Días disponibles"
                android:textColor="@color/app_text"
                android:textSize="18sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:orientation="horizontal"
                android:gravity="center">

                <TextView android:id="@+id/dayMon" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:text="L" android:layout_margin="2dp" android:background="@drawable/detail_bg_day_unavailable" android:textColor="@color/light_grey" />
                <TextView android:id="@+id/dayTue" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:text="M" android:layout_margin="2dp" android:background="@drawable/detail_bg_day_unavailable" android:textColor="@color/light_grey" />
                <TextView android:id="@+id/dayWed" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:text="X" android:layout_margin="2dp" android:background="@drawable/detail_bg_day_unavailable" android:textColor="@color/light_grey" />
                <TextView android:id="@+id/dayThu" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:text="J" android:layout_margin="2dp" android:background="@drawable/detail_bg_day_unavailable" android:textColor="@color/light_grey" />
                <TextView android:id="@+id/dayFri" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:text="V" android:layout_margin="2dp" android:background="@drawable/detail_bg_day_unavailable" android:textColor="@color/light_grey" />
                <TextView android:id="@+id/daySat" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:text="S" android:layout_margin="2dp" android:background="@drawable/detail_bg_day_unavailable" android:textColor="@color/light_grey" />
                <TextView android:id="@+id/daySun" android:layout_width="40dp" android:layout_height="40dp" android:gravity="center" android:text="D" android:layout_margin="2dp" android:background="@drawable/detail_bg_day_unavailable" android:textColor="@color/light_grey" />
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:fontFamily="@font/plus_jakarta_sans_bold"
                android:text="Horarios"
                android:textColor="@color/app_text"
                android:textSize="18sp" />

            <TextView
                android:id="@+id/textSchedules"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:textColor="@color/app_text_secondary"
                tools:text="• 2023-10-25 - 10:00 | Cupos: 5" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:fontFamily="@font/plus_jakarta_sans_bold" android:text="Política de cancelación" android:textColor="@color/app_text" android:textSize="18sp" />
            <TextView android:id="@+id/textCancellationPolicy" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="8dp" android:text="Cancelación gratuita hasta 48 horas antes de la actividad." android:textColor="@color/app_text_secondary" />

            <!-- SECCIÓN COMENTARIOS -->
            <TextView android:id="@+id/textCommentsHeader" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="24dp" android:fontFamily="@font/plus_jakarta_sans_bold" android:text="Opiniones" android:textColor="@color/app_text" android:textSize="18sp" />
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerComments" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:nestedScrollingEnabled="false" />
            <TextView android:id="@+id/textNoComments" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginTop="12dp" android:gravity="center" android:text="Aún no hay opiniones." android:visibility="gone" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnReserve"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="32dp"
                android:text="Reservar ahora"
                android:textColor="@android:color/white"
                app:backgroundTint="@color/app_primary"
                app:cornerRadius="16dp"
                android:fontFamily="@font/plus_jakarta_sans_bold" />

        </LinearLayout>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
