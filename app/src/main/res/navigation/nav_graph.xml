<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/WelcomeFragment">

    <fragment
        android:id="@+id/WelcomeFragment"
        android:name="com.example.androidnativegrupo5.ui.auth.WelcomeFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_welcome">
        <action
            android:id="@+id/action_WelcomeFragment_to_LoginFragment"
            app:destination="@id/LoginFragment" />
        <action
            android:id="@+id/action_WelcomeFragment_to_FirstFragment"
            app:destination="@id/FirstFragment"
            app:popUpTo="@id/WelcomeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_WelcomeFragment_to_RegisterFragment"
            app:destination="@id/RegisterFragment"
            app:popUpTo="@id/WelcomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/LoginFragment"
        android:name="com.example.androidnativegrupo5.ui.auth.LoginFragment"
        android:label="@string/iniciar_sesion"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_LoginFragment_to_OtpFragment"
            app:destination="@id/OtpFragment" />
        <action
            android:id="@+id/action_LoginFragment_to_RegisterFragment"
            app:destination="@id/RegisterFragment" />
        <action
            android:id="@+id/action_LoginFragment_to_FirstFragment"
            app:destination="@id/FirstFragment"
            app:popUpTo="@id/WelcomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/OtpFragment"
        android:name="com.example.androidnativegrupo5.ui.auth.OtpFragment"
        android:label="@string/verify_identity"
        tools:layout="@layout/fragment_otp">
        <argument
            android:name="email"
            app:argType="string" />
        <action
            android:id="@+id/action_OtpFragment_to_FirstFragment"
            app:destination="@id/FirstFragment"
            app:popUpTo="@id/WelcomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/RegisterFragment"
        android:name="com.example.androidnativegrupo5.ui.auth.RegisterFragment"
        android:label="Register">
        <action
            android:id="@+id/action_registerFragment_to_otpFragment"
            app:destination="@id/OtpFragment" />
    </fragment>

    <fragment
        android:id="@+id/FirstFragment"
        android:name="com.example.androidnativegrupo5.ui.activities.HomeFragment"
        android:label="Actividades">
        <action
            android:id="@+id/action_FirstFragment_to_DetailFragment"
            app:destination="@id/DetailFragment" />
        <action
            android:id="@+id/action_FirstFragment_to_MyReservationsFragment"
            app:destination="@id/MyReservationsFragment" />
        <action
            android:id="@+id/action_FirstFragment_to_ExploreActivitiesFragment"
            app:destination="@id/ExploreActivitiesFragment" />
    </fragment>

    <fragment
        android:id="@+id/DetailFragment"
        android:name="com.example.androidnativegrupo5.ui.activities.DetailFragment"
        android:label="Detalle">
        <argument
            android:name="activityId"
            app:argType="long" />
        <action
            android:id="@+id/action_DetailFragment_to_ReservationFragment"
            app:destination="@id/ReservationFragment" />
    </fragment>

    <fragment
        android:id="@+id/MyReservationsFragment"
        android:name="com.example.androidnativegrupo5.ui.reservations.MyReservationsFragment"
        android:label="Mis Reservas"
        tools:layout="@layout/fragment_my_reservations">

        <action
            android:id="@+id/action_MyReservationsFragment_to_HistoryFragment"
            app:destination="@id/HistoryFragment" />
    </fragment>

    <fragment
        android:id="@+id/ReservationFragment"
        android:name="com.example.androidnativegrupo5.ui.reservations.ReservationFragment"
        android:label="Reservar"
        tools:layout="@layout/fragment_reservation">
        <argument android:name="activityId" app:argType="long" />
        <argument android:name="activityName" app:argType="string" />
        <argument android:name="activityPrice" app:argType="float" />
    </fragment>

    <fragment
        android:id="@+id/ProfileFragment"
        android:name="com.example.androidnativegrupo5.ui.profile.ProfileFragment"
        android:label="Perfil del Viajero"
        tools:layout="@layout/fragment_profile" />

    <fragment
        android:id="@+id/HistoryFragment"
        android:name="com.example.androidnativegrupo5.ui.activities.HistoryFragment"
        android:label="Historial"
        tools:layout="@layout/fragment_history">

        <action
            android:id="@+id/action_HistoryFragment_to_DetailFragment"
            app:destination="@id/DetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/ExploreActivitiesFragment"
        android:name="com.example.androidnativegrupo5.ui.activities.ExploreActivitiesFragment"
        android:label="Todas las actividades"
        tools:layout="@layout/fragment_explore_activities">
        <action
            android:id="@+id/action_ExploreActivitiesFragment_to_DetailFragment"
            app:destination="@id/DetailFragment" />
    </fragment>

</navigation>