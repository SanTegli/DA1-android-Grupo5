<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/WelcomeFragment">

    <fragment
        android:id="@+id/WelcomeFragment"
        android:name="com.example.androidnativegrupo5.ui.auth.WelcomeFragment"
        android:label="Welcome"
        tools:layout="@layout/fragment_welcome">
        <action
            android:id="@+id/action_WelcomeFragment_to_LoginFragment"
            app:destination="@id/LoginFragment" />
        <action
            android:id="@+id/action_WelcomeFragment_to_FirstFragment"
            app:destination="@id/FirstFragment"
            app:popUpTo="@id/WelcomeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_WelcomeFragment_to_RegisterFragment"
            app:destination="@id/RegisterFragment"
            app:popUpTo="@id/WelcomeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_WelcomeFragment_to_OfflineFragment"
            app:destination="@id/OfflineFragment" />
    </fragment>

    <fragment
        android:id="@+id/OfflineFragment"
        android:name="com.example.androidnativegrupo5.ui.auth.OfflineFragment"
        android:label="Sin Conexión"
        tools:layout="@layout/fragment_offline">
        <action
            android:id="@+id/action_OfflineFragment_to_MyReservationsFragment"
            app:destination="@id/MyReservationsFragment" />
    </fragment>

    <fragment
        android:id="@+id/LoginFragment"
        android:name="com.example.androidnativegrupo5.ui.auth.LoginFragment"
        android:label="@string/iniciar_sesion"
        tools:layout="@layout/fragment_login">
        <action
            android:id="@+id/action_LoginFragment_to_OtpFragment"
            app:destination="@id/OtpFragment" />
        <action
            android:id="@+id/action_LoginFragment_to_RegisterFragment"
            app:destination="@id/RegisterFragment" />
        <action
            android:id="@+id/action_LoginFragment_to_FirstFragment"
            app:destination="@id/FirstFragment"
            app:popUpTo="@id/WelcomeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_LoginFragment_to_OfflineFragment"
            app:destination="@id/OfflineFragment" />
    </fragment>

    <fragment
        android:id="@+id/FirstFragment"
        android:name="com.example.androidnativegrupo5.ui.activities.HomeFragment"
        android:label="Actividades">
        <action
            android:id="@+id/action_FirstFragment_to_DetailFragment"
            app:destination="@id/DetailFragment" />
        <action
            android:id="@+id/action_FirstFragment_to_OfflineFragment"
            app:destination="@id/OfflineFragment"
            app:popUpTo="@id/WelcomeFragment"
            app:popUpToInclusive="true" />
        <action
            android:id="@+id/action_FirstFragment_to_ExploreActivitiesFragment"
            app:destination="@id/ExploreActivitiesFragment" />
    </fragment>

    <fragment
        android:id="@+id/MyReservationsFragment"
        android:name="com.example.androidnativegrupo5.ui.reservations.MyReservationsFragment"
        android:label="Mis Reservas"
        tools:layout="@layout/fragment_my_reservations">
        <action
            android:id="@+id/action_MyReservationsFragment_to_HistoryFragment"
            app:destination="@id/HistoryFragment" />
        <action
            android:id="@+id/action_MyReservationsFragment_to_ManageReservationFragment"
            app:destination="@id/ManageReservationFragment" />
    </fragment>

    <fragment
        android:id="@+id/DetailFragment"
        android:name="com.example.androidnativegrupo5.ui.activities.DetailFragment"
        android:label="Detalle">
        <argument android:name="activityId" app:argType="long" />
        <action
            android:id="@+id/action_DetailFragment_to_ReservationFragment"
            app:destination="@id/ReservationFragment" />
    </fragment>

    <fragment
        android:id="@+id/ReservationFragment"
        android:name="com.example.androidnativegrupo5.ui.reservations.ReservationFragment"
        android:label="Reservar"
        tools:layout="@layout/fragment_reservation">
        <argument
            android:name="activityId"
            app:argType="long" />
        <argument
            android:name="activityName"
            app:argType="string" />
        <argument
            android:name="activityPrice"
            app:argType="float" />
        <action
            android:id="@+id/action_ReservationFragment_to_OrderSummaryFragment"
            app:destination="@id/OrderSummaryFragment" />
    </fragment>

    <fragment
        android:id="@+id/OrderSummaryFragment"
        android:name="com.example.androidnativegrupo5.ui.reservations.OrderSummaryFragment"
        android:label="Resumen de Pago"
        tools:layout="@layout/fragment_order_summary">
        <argument android:name="activityId" app:argType="long" />
        <argument android:name="activityName" app:argType="string" />
        <argument android:name="activityPrice" app:argType="float" />
        <argument android:name="slots" app:argType="integer" />
        <argument android:name="date" app:argType="string" />
        <argument android:name="time" app:argType="string" />
        <action
            android:id="@+id/action_OrderSummaryFragment_to_MyReservationsFragment"
            app:destination="@id/MyReservationsFragment"
            app:popUpTo="@id/FirstFragment" />
    </fragment>

    <fragment
        android:id="@+id/TransactionsFragment"
        android:name="com.example.androidnativegrupo5.ui.profile.TransactionsFragment"
        android:label="Transacciones"
        tools:layout="@layout/fragment_transactions">
        <action
            android:id="@+id/action_TransactionsFragment_to_ManageReservationFragment"
            app:destination="@id/ManageReservationFragment" />
    </fragment>

    <fragment
        android:id="@+id/ExploreActivitiesFragment"
        android:name="com.example.androidnativegrupo5.ui.activities.ExploreActivitiesFragment"
        android:label="Explorar">
        <action
            android:id="@+id/action_ExploreActivitiesFragment_to_DetailFragment"
            app:destination="@id/DetailFragment" />
        <action
            android:id="@+id/action_ExploreActivitiesFragment_to_MyReservationsFragment"
            app:destination="@id/MyReservationsFragment" />
    </fragment>

    <fragment
        android:id="@+id/HistoryFragment"
        android:name="com.example.androidnativegrupo5.ui.activities.HistoryFragment"
        android:label="Historial">
        <action
            android:id="@+id/action_HistoryFragment_to_DetailReservationFragment"
            app:destination="@id/ManageReservationFragment" />
        <action
            android:id="@+id/action_HistoryFragment_to_RatingFragment"
            app:destination="@id/RatingFragment" />
    </fragment>

    <fragment
        android:id="@+id/RatingFragment"
        android:name="com.example.androidnativegrupo5.ui.activities.RatingFragment"
        android:label="Calificar"
        tools:layout="@layout/fragment_rating">
        <argument
            android:name="activityId"
            app:argType="long" />
        <argument
            android:name="activityName"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/ProfileFragment"
        android:name="com.example.androidnativegrupo5.ui.profile.ProfileFragment"
        android:label="Perfil" >
        <action
            android:id="@+id/action_ProfileFragment_to_MyReservationsFragment"
            app:destination="@id/MyReservationsFragment" />
        <action
            android:id="@+id/action_ProfileFragment_to_HistoryFragment"
            app:destination="@id/HistoryFragment" />
        <action
            android:id="@+id/action_ProfileFragment_to_FavoritesFragment"
            app:destination="@id/FavoritesFragment" />
        <action
            android:id="@+id/action_ProfileFragment_to_TransactionsFragment"
            app:destination="@id/TransactionsFragment" />
    </fragment>

    <fragment
        android:id="@+id/OtpFragment"
        android:name="com.example.androidnativegrupo5.ui.auth.OtpFragment"
        android:label="OTP">
        <action
            android:id="@+id/action_OtpFragment_to_FirstFragment"
            app:destination="@id/FirstFragment"
            app:popUpTo="@id/WelcomeFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <fragment
        android:id="@+id/RegisterFragment"
        android:name="com.example.androidnativegrupo5.ui.auth.RegisterFragment"
        android:label="Registro">
        <action
            android:id="@+id/action_registerFragment_to_otpFragment"
            app:destination="@id/OtpFragment" />
    </fragment>

    <fragment
        android:id="@+id/FavoritesFragment"
        android:name="com.example.androidnativegrupo5.ui.favorites.FavoritesFragment"
        android:label="Favoritos"
        tools:layout="@layout/fragment_favorites">
        <action
            android:id="@+id/action_FavoritesFragment_to_DetailFragment"
            app:destination="@id/DetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/ManageReservationFragment"
        android:name="com.example.androidnativegrupo5.ui.reservations.DetailReservationFragment"
        android:label="Gestionar Reserva"
        tools:layout="@layout/fragment_manage_reservation">
        <argument
            android:name="reservationId"
            app:argType="long" />
        <argument
            android:name="activityId"
            app:argType="long" />
        <action
            android:id="@+id/action_ManageReservationFragment_to_RatingFragment"
            app:destination="@id/RatingFragment" />
        <action
            android:id="@+id/action_ManageReservationFragment_to_TransactionsFragment"
            app:destination="@id/TransactionsFragment" />
    </fragment>

</navigation>
